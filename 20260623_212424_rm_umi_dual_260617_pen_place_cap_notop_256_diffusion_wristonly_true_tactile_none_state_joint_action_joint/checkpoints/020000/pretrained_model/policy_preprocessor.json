{
  "name": "policy_preprocessor",
  "steps": [
    {
      "registry_name": "rename_observations_processor",
      "config": {
        "rename_map": {}
      }
    },
    {
      "registry_name": "to_batch_processor",
      "config": {}
    },
    {
      "registry_name": "delta_actions_processor",
      "config": {
        "enabled": false,
        "exclude_joints": [],
        "action_names": null,
        "mode": "joint",
        "n_arms": 2
      }
    },
    {
      "registry_name": "device_processor",
      "config": {
        "device": "cuda",
        "float_dtype": null
      }
    },
    {
      "registry_name": "normalizer_processor",
      "config": {
        "eps": 1e-08,
        "features": {
          "observation.state": {
            "type": "STATE",
            "shape": [
              16
            ]
          },
          "observation.images.left_cam_wrist": {
            "type": "VISUAL",
            "shape": [
              3,
              224,
              224
            ]
          },
          "observation.images.right_cam_wrist": {
            "type": "VISUAL",
            "shape": [
              3,
              224,
              224
            ]
          },
          "action": {
            "type": "ACTION",
            "shape": [
              16
            ]
          }
        },
        "norm_map": {
          "VISUAL": "MEAN_STD",
          "STATE": "MIN_MAX",
          "ACTION": "MIN_MAX"
        }
      },
      "state_file": "policy_preprocessor_step_4_normalizer_processor.safetensors"
    }
  ]
}